# в”Җв”Җ 4. priceе’ҢDPH/demand ratioзҡ„е…ізі»пјҲйӘҢиҜҒдҪ зҡ„еҒҮи®ҫпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
print("\n=== PRICE vs DPH/DEMAND RATIO ===")
asin_stats = df.groupby("asin").agg(
    mean_instock=("in_stock_dph", "mean"),
    mean_demand=("fbi_demand", "mean"),
    mean_price=("our_price", "mean"),
    gl=("gl_product_group", "first"),
).reset_index()
asin_stats["dph_demand_ratio"] = (
    asin_stats["mean_instock"] / (asin_stats["mean_demand"] + 1e-8)
)
price_q = asin_stats["mean_price"].clip(
    upper=asin_stats["mean_price"].quantile(0.99)
)
ratio_q = asin_stats["dph_demand_ratio"].clip(
    upper=asin_stats["dph_demand_ratio"].quantile(0.99)
)
corr = price_q.corr(ratio_q, method="spearman")
print(f"Spearman corr price vs dph/demand ratio: {corr:.4f}")

asin_stats["price_group"] = pd.qcut(
    price_q.rank(method="first"), q=4,
    labels=["low","mid","high","premium"]
)
pg = asin_stats.groupby("price_group", observed=True).agg(
    n=("asin","count"),
    median_price=("mean_price","median"),
    median_ratio=("dph_demand_ratio","median"),
    median_instock=("mean_instock","median"),
).reset_index()
print(pg.round(3).to_string(index=False))

