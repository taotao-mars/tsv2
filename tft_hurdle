# 1. DATA
# ============================================================

def _safe_num(s, fill=0.0):
    return pd.to_numeric(s, errors="coerce").fillna(fill)


def _encode_static(df):
    out = []
    for c in ["gl_product_group", "ind_top10_brand"]:
        if c not in df.columns:
            continue
        raw = df[c].astype(str).fillna("MISSING")
        codes, uniques = pd.factorize(raw)
        df[f"static_{c}_code"] = codes / max(len(uniques) - 1, 1)
        df[f"static_{c}_freq"] = raw.map(raw.value_counts(normalize=True)).fillna(0.0)
        out += [f"static_{c}_code", f"static_{c}_freq"]
    return df, out


def _event_calendar(min_year, max_year):
    rows = []
    for y in range(min_year - 1, max_year + 2):
        nov = pd.date_range(f"{y}-11-01", f"{y}-11-30", freq="D")
        tg = nov[nov.weekday == 3][3]
        for name, date in [
            ("NewYear",      pd.Timestamp(f"{y}-01-01")),
            ("PrimeDay",     pd.Timestamp(f"{y}-07-15")),
            ("BackToSchool", pd.Timestamp(f"{y}-08-15")),
            ("Thanksgiving", tg),
            ("BlackFriday",  tg + pd.Timedelta(days=1)),
            ("CyberMonday",  tg + pd.Timedelta(days=4)),
            ("Christmas",    pd.Timestamp(f"{y}-12-25")),
        ]:
            rows.append({"name": name, "week": date.to_period("W-SUN").start_time})
    return pd.DataFrame(rows)


def _add_event_features(df, week_col="order_week", window=2):
    df = df.copy()
    df["_wk"] = pd.to_datetime(df[week_col]).dt.to_period("W-SUN").apply(lambda r: r.start_time)
    cal = _event_calendar(df[week_col].dt.year.min(), df[week_col].dt.year.max())
    names = sorted(cal["name"].unique())

    df["is_event_window"] = 0.0
    df["weeks_to_event"]  = 99.0
    for n in names:
        df[f"event_{n}_win"] = 0.0

    for _, r in cal.iterrows():
        diff = ((df["_wk"] - r["week"]).dt.days / 7).round().astype(int)
        win  = diff.abs() <= window
        df.loc[win, "is_event_window"] = 1.0
        df.loc[win, f"event_{r['name']}_win"] = 1.0
        better = diff.abs() < df["weeks_to_event"].abs()
        df.loc[better, "weeks_to_event"] = diff[better].clip(-20, 20) / 20.0

    df = df.drop(columns=["_wk"])
    event_cols = ["is_event_window", "weeks_to_event"] + [f"event_{n}_win" for n in names]
    return df, event_cols


def prepare_data(data_raw1, scot_df, n_asins=5000, seed=42):
    df   = data_raw1.copy()
    scot = scot_df.copy()
    df["asin"]       = df["asin"].astype(str)
    scot["asin"]     = scot["asin"].astype(str)
    df["order_week"] = pd.to_datetime(df["order_week"])

    rng   = np.random.default_rng(seed)
    asins = rng.choice(df["asin"].unique(), size=min(n_asins, df["asin"].nunique()), replace=False)
    keep  = sorted(set(asins) & set(scot["asin"].unique()))
    print(f"ASINs after intersection: {len(keep)}")
    return df[df["asin"].isin(keep)].copy()


def filter_extremes(df, q=0.99):
    stats = df.groupby("asin")[["fbi_demand","total_dph","buy_box_dph","in_stock_dph"]].max()
    mask  = (stats <= stats.quantile(q)).all(axis=1)
    keep  = stats[mask].index
    print(f"ASINs after extreme filter: {len(keep)}")
    return df[df["asin"].isin(keep)].copy()


def load_data(df, dph_cap_q=0.995):
    df = df.copy()
    df["asin"]       = df["asin"].astype(str)
    df["order_week"] = pd.to_datetime(df["order_week"])
    df = df.sort_values(["asin", "order_week"]).reset_index(drop=True)

    for c in ["fbi_demand", "total_dph", "buy_box_dph", "in_stock_dph"]:
        df[c] = _safe_num(df[c]).clip(lower=0.0)
    for c in ["total_dph", "buy_box_dph", "in_stock_dph"]:
        df[c] = df[c].clip(upper=df[c].quantile(dph_cap_q))

    df["our_price"] = _safe_num(df.get("our_price", 0.0)).clip(lower=0.0)
    df["scot_oos"]  = _safe_num(df.get("scot_oos",  0.0)).clip(0, 1)

    df["month"]      = df["order_week"].dt.month.astype(float)
    df["month_sin"]  = np.sin(2 * np.pi * df["month"] / 12)
    df["month_cos"]  = np.cos(2 * np.pi * df["month"] / 12)

    df, event_cols  = _add_event_features(df)
    df, static_cols = _encode_static(df)

    holiday_cols   = [c for c in df.columns if c.startswith("holiday_indicator_")]
    distance_cols  = [c for c in df.columns if c.startswith("distance_")]
    for c in holiday_cols + distance_cols:
        df[c] = _safe_num(df[c])

    ctx_cols = (
        ["our_price", "month", "month_sin", "month_cos"]
        + holiday_cols + distance_cols
        + event_cols + static_cols
        + ["hist_total_last", "hist_total_mean4", "hist_total_mean13",
           "hist_buy_last",   "hist_buy_mean4",   "hist_buy_mean13",
           "hist_instock_last","hist_instock_mean4","hist_instock_mean13"]
    )
    ctx_cols = list(dict.fromkeys(ctx_cols))
    for c in ctx_cols:
        if c not in df.columns:
            df[c] = 0.0

    asin_data = {}
    for asin, g in df.groupby("asin"):
        g = g.sort_values("order_week").reset_index(drop=True)
        T = len(g)
        idx = np.arange(T)

        price = g["our_price"].values.astype(np.float32)
        if price.std() > 1e-8:
            price = (price - price.mean()) / (price.std() + 1e-8)

        feats = np.stack([
            np.log1p(g["fbi_demand"].values),
            (g["fbi_demand"].values > 0).astype(float),
            np.log1p(g["total_dph"].values),
            np.log1p(g["buy_box_dph"].values),
            np.log1p(g["in_stock_dph"].values),
            price,
            g["scot_oos"].values,
            np.sin(2 * np.pi * idx / 52),
            np.cos(2 * np.pi * idx / 52),
        ], axis=1).astype(np.float32)

        asin_data[asin] = {
            "week":         g["order_week"].values,
            "features":     feats,
            "demand":       g["fbi_demand"].values.astype(np.float32),
            "total_dph":    g["total_dph"].values.astype(np.float32),
            "buy_box_dph":  g["buy_box_dph"].values.astype(np.float32),
            "in_stock_dph": g["in_stock_dph"].values.astype(np.float32),
            "future_ctx":   g[ctx_cols].values.astype(np.float32),
            "ctx_cols":     ctx_cols,
        }

    print(f"Loaded {len(asin_data)} ASINs | ctx_dim={len(ctx_cols)}")
    return asin_data, len(ctx_cols), ctx_cols


