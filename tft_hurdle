# 4. PIPELINE A: BEST-ATTN
#    TCN Encoder + AnchorAttention Blender
# ============================================================

# -- 4a. TCN Encoder --

class CausalConv1d(nn.Module):
    def __init__(self, d, k=2, dil=1):
        super().__init__()
        self.pad  = (k - 1) * dil
        self.conv = nn.Conv1d(d, d, k, dilation=dil)

    def forward(self, x):
        return self.conv(F.pad(x, (self.pad, 0)))


class TCNEncoder(nn.Module):
    def __init__(self, input_dim, d_model=64):
        super().__init__()
        self.proj = nn.Linear(input_dim, d_model)
        dilations = [1, 2, 4, 8, 13, 26]
        self.convs = nn.ModuleList([CausalConv1d(d_model, dil=d) for d in dilations])
        self.norms = nn.ModuleList([nn.LayerNorm(d_model) for _ in dilations])
        self.final = nn.LayerNorm(d_model)

    def forward(self, x):                       # x: [B,T,F]
        h = self.proj(x).transpose(1, 2)        # [B,D,T]
        for conv, norm in zip(self.convs, self.norms):
            h = h + conv(h)
            h = F.gelu(norm(h.transpose(1, 2))).transpose(1, 2)
        return self.final(h.transpose(1, 2)[:, -1, :])   # [B,D]


class TCNDecoder(nn.Module):
    def __init__(self, d_model, ctx_dim, horizon=20, hidden=96, dropout=0.1):
        super().__init__()
        self.proj = nn.Sequential(
            nn.Linear(d_model + ctx_dim + 2, hidden), nn.ReLU(), nn.Dropout(dropout))
        self.tcn  = nn.ModuleList([
            self._block(hidden, dil, dropout) for dil in [1, 2, 4]])
        self.head = nn.Sequential(
            nn.Linear(hidden, hidden), nn.ReLU(), nn.Dropout(dropout * 0.5),
            nn.Linear(hidden, 3))
        self.H = horizon

    @staticmethod
    def _block(d, dil, drop):
        pad = dil
        return nn.Sequential(
            nn.Conv1d(d, d, 3, padding=pad, dilation=dil), nn.ReLU(), nn.Dropout(drop),
            nn.Conv1d(d, d, 3, padding=pad, dilation=dil), nn.ReLU(), nn.Dropout(drop))

    def forward(self, h_t, ctx):               # h_t:[B,D]  ctx:[B,H,C]
        B, H, _ = ctx.shape
        h_rep = h_t.unsqueeze(1).expand(B, H, -1)
        hpos  = torch.arange(H, device=ctx.device).float().view(1, H, 1).expand(B, H, 1) / H
        hsin  = torch.sin(2 * np.pi * hpos)
        hcos  = torch.cos(2 * np.pi * hpos)
        z = self.proj(torch.cat([h_rep, ctx, hsin, hcos], -1))  # [B,H,hidden]
        for blk in self.tcn:
            r = z.transpose(1, 2)
            out = blk(r)
            if out.shape[2] != r.shape[2]:
                m = min(out.shape[2], r.shape[2])
                out, r = out[:, :, :m], r[:, :, :m]
            z = nn.LayerNorm(z.shape[-1]).to(z.device)(z + out.transpose(1, 2))
        return F.softplus(self.head(z))         # [B,H,3]


class TCNExposureModel(nn.Module):
    def __init__(self, input_dim, ctx_dim, d_model=64, horizon=20):
        super().__init__()
        self.encoder = TCNEncoder(input_dim, d_model)
        self.decoder = TCNDecoder(d_model, ctx_dim, horizon, max(96, d_model * 2))

    def forward(self, x, ctx):
        return self.decoder(self.encoder(x), ctx)


# -- 4b. Anchor Attention Blender --

class AnchorBlender(nn.Module):
    """Learns weights over [model, naive_last, naive_mean4, naive_mean13]."""
    def __init__(self, input_dim, hidden=64, dropout=0.1):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden), nn.ReLU(), nn.Dropout(dropout),
            nn.Linear(hidden, hidden),   nn.ReLU(), nn.Dropout(dropout),
            nn.Linear(hidden, 4))

    def forward(self, x, candidates):
        w = torch.softmax(self.net(x), dim=-1)
        return (w * candidates).sum(-1), w


def _blender_features(pred_df, ctx_cols, target="in_stock_dph"):
    mapping = {
        "in_stock_dph": ("true_instock_dph",  "pred_instock_dph",
                         ["naive_instock_last","naive_instock_mean4","naive_instock_mean13"]),
        "buy_box_dph":  ("true_buy_box_dph",   "pred_buy_box_dph",
                         ["naive_buy_last","naive_buy_mean4","naive_buy_mean13"]),
        "total_dph":    ("true_total_dph",      "pred_total_dph",
                         ["naive_total_last","naive_total_mean4","naive_total_mean13"]),
    }
    true_col, pred_col, naive_cols = mapping[target]

    df = pred_df.copy()
    h  = df["horizon"].astype(float).values
    hn = h / h.max()

    cands = df[[pred_col] + naive_cols].fillna(0).clip(lower=0).values.astype(np.float32)
    cands_log = np.log1p(cands)
    cz = (cands_log - cands_log.mean(1, keepdims=True)) / (cands_log.std(1, keepdims=True) + 1e-6)

    h_feat = np.stack([hn, np.sin(2*np.pi*hn), np.cos(2*np.pi*hn),
                       (h<=5).astype(float), ((h>5)&(h<=12)).astype(float),
                       (h>12).astype(float)], axis=1).astype(np.float32)

    X = np.concatenate([h_feat, cands_log, cz], axis=1).astype(np.float32)
    xm = X.mean(0, keepdims=True); xs = X.std(0, keepdims=True) + 1e-6
    Xn = (X - xm) / xs

    y = df[true_col].fillna(0).clip(lower=0).values.astype(np.float32)
    return Xn, cands, y, xm, xs


def _train_blender(Xn, cands, y, hidden=64, epochs=80, lr=1e-3, patience=10, seed=42):
    torch.manual_seed(seed); np.random.seed(seed)
    n = len(Xn)
    idx = np.random.permutation(n)
    nv  = max(int(0.2 * n), 1)
    vi, ti = idx[:nv], idx[nv:]

    def batch(I, bs=1024):
        for i in range(0, len(I), bs):
            sl = I[i:i+bs]
            yield (torch.tensor(Xn[sl]), torch.tensor(cands[sl]), torch.tensor(y[sl]))

    model = AnchorBlender(Xn.shape[1], hidden)
    opt   = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-5)
    best_val, best_sd, no_imp = float("inf"), None, 0

    for ep in range(epochs):
        model.train()
        for xb, cb, yb in batch(ti):
            pred, w = model(xb, cb)
            loss = F.huber_loss(torch.log1p(pred.clamp(0)), torch.log1p(yb.clamp(0)))
            opt.zero_grad(); loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0); opt.step()

        model.eval()
        vl = []
        with torch.no_grad():
            for xb, cb, yb in batch(vi):
                pred, _ = model(xb, cb)
                vl.append(F.huber_loss(torch.log1p(pred.clamp(0)), torch.log1p(yb.clamp(0))).item())
        vl = float(np.mean(vl))
        if vl < best_val - 1e-6:
            best_val = vl
            best_sd  = {k: v.clone() for k, v in model.state_dict().items()}
            no_imp   = 0
        else:
            no_imp += 1
        if no_imp >= patience:
            break

    model.load_state_dict(best_sd)
    return model


def _apply_blender(pred_df, model, Xn, cands, target, out_col):
    model.eval()
    with torch.no_grad():
        pred, w = model(torch.tensor(Xn), torch.tensor(cands))
    out = pred_df.copy()
    out[out_col] = pred.numpy()
    cols = ["w_model","w_last","w_mean4","w_mean13"]
    for j, c in enumerate(cols):
        out[f"attn_{target}_{c}"] = w[:, j].numpy()
    return out


def run_anchor_attention(pred_df, targets=("total_dph","buy_box_dph","in_stock_dph")):
    out = pred_df.copy()
    col_map = {"in_stock_dph":"pred_instock_dph",
               "buy_box_dph": "pred_buy_box_dph",
               "total_dph":   "pred_total_dph"}
    for target in targets:
        print(f"  Training blender: {target}")
        Xn, cands, y, _, _ = _blender_features(out, [], target)
        model = _train_blender(Xn, cands, y)
        out   = _apply_blender(out, model, Xn, cands, target, col_map[target])
    return out


# -- 4c. TCN loss + train --

def tcn_loss(log_hat, true_total, true_buy, true_instock,
             w=(0.3, 0.6, 1.0), mean_w=0.2):
    true = torch.stack([true_total.clamp(0), true_buy.clamp(0), true_instock.clamp(0)], -1)
    tw   = torch.tensor(w, device=log_hat.device).view(1,1,3)
    pt   = F.huber_loss(log_hat, torch.log1p(true), delta=1.0, reduction="none")
    pt   = (pt * tw).mean()
    pl   = torch.expm1(log_hat).clamp(0)
    mp   = torch.log1p(pl.mean((0,1)))
    mt   = torch.log1p(true.mean((0,1)))
    ml   = (torch.abs(mp - mt) * tw.view(3)).mean()
    return pt + mean_w * ml


def _train_loop(model, tr_ld, va_ld, loss_fn, epochs, lr, patience, tag=""):
    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-5)
    sch = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=max(epochs,1))
    best_val, best_sd, no_imp = float("inf"), None, 0

    for ep in range(epochs):
        model.train()
        tl, tn = 0.0, 0
        for b in tr_ld:
            out  = model(b["x"], b["future_ctx"])
            loss = loss_fn(out, b["future_total"], b["future_buy"], b["future_instock"])
            opt.zero_grad(); loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0); opt.step()
            tl += loss.item() * b["x"].shape[0]; tn += b["x"].shape[0]
        sch.step()

        model.eval(); vl, vn = 0.0, 0
        with torch.no_grad():
            for b in va_ld:
                out  = model(b["x"], b["future_ctx"])
                loss = loss_fn(out, b["future_total"], b["future_buy"], b["future_instock"])
                vl  += loss.item() * b["x"].shape[0]; vn += b["x"].shape[0]

        tl /= max(tn,1); vl /= max(vn,1)
        print(f"[{tag}] Ep {ep+1:03d} | train={tl:.5f} | val={vl:.5f}")

        if vl < best_val - 1e-6:
            best_val = vl
            best_sd  = {k: v.clone() for k, v in model.state_dict().items()}
            no_imp   = 0
        else:
            no_imp += 1
        if no_imp >= patience:
            print(f"[{tag}] Early stop. best_val={best_val:.5f}"); break

    model.load_state_dict(best_sd)
    return model


def _predict(model, va_ld):
    rows = []; model.eval()
    with torch.no_grad():
        for b in va_ld:
            pred = torch.expm1(model(b["x"], b["future_ctx"])).clamp(0).cpu().numpy()
            B, H = b["future_instock"].shape
            for i in range(B):
                for h in range(H):
                    rows.append({
                        "asin":           b["asin"][i],
                        "order_week":     pd.to_datetime(b["target_week"][h][i]),
                        "horizon":        h + 1,
                        "true_total_dph":  b["future_total"][i,h].item(),
                        "pred_total_dph":  pred[i,h,0],
                        "true_buy_box_dph":b["future_buy"][i,h].item(),
                        "pred_buy_box_dph":pred[i,h,1],
                        "true_instock_dph":b["future_instock"][i,h].item(),
                        "pred_instock_dph":pred[i,h,2],
                        "true_demand":     b["future_demand"][i,h].item(),
                    })
    return pd.DataFrame(rows)


# -- 4d. Best-Attn runner --

def run_best_attn(data_raw1, scot_df, n_asins=5000, seed=42,
                  history=52, horizon=20, d_model=64, batch_size=64,
                  epochs=60, lr=1e-3, patience=8):
    print("\n" + "="*80 + "\nPIPELINE A: BEST-ATTN\n" + "="*80)

    df = prepare_data(data_raw1, scot_df, n_asins, seed)
    df = filter_extremes(df)
    asin_data, ctx_dim, ctx_cols = load_data(df)
