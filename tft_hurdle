    }


# ============================================================
# 5. PIPELINE B: TFT-HURDLE
#    VSN + LSTM Encoder + LSTM Decoder + CrossAttn + Hurdle Head
# ============================================================

class GRN(nn.Module):
    def __init__(self, in_d, hid, out_d, dropout=0.1):
        super().__init__()
        self.fc1  = nn.Linear(in_d, hid)
        self.fc2  = nn.Linear(hid,  out_d)
        self.gate = nn.Sequential(nn.Linear(hid, out_d), nn.Sigmoid())
        self.skip = nn.Linear(in_d, out_d) if in_d != out_d else nn.Identity()
        self.norm = nn.LayerNorm(out_d)
        self.drop = nn.Dropout(dropout)

    def forward(self, x):
        z = self.drop(F.elu(self.fc1(x)))
        return self.norm(self.skip(x) + self.gate(z) * self.fc2(z))


class VSN(nn.Module):
    def __init__(self, n_vars, d_model=64, hidden=64, dropout=0.1):
        super().__init__()
        self.proj   = nn.ModuleList([nn.Linear(1, d_model) for _ in range(n_vars)])
        self.w_net  = nn.Sequential(
            nn.Linear(n_vars, hidden), nn.ReLU(), nn.Dropout(dropout),
            nn.Linear(hidden, n_vars))
        self.post   = GRN(d_model, hidden, d_model, dropout)
        self.n_vars = n_vars

    def forward(self, x):                       # x: [B,T,F]
        B, T, F = x.shape
        embs = torch.stack([self.proj[j](x[:,:,j:j+1]) for j in range(F)], dim=-2)  # [B,T,F,D]
        w    = torch.softmax(self.w_net(x), dim=-1)                                  # [B,T,F]
        sel  = (embs * w.unsqueeze(-1)).sum(-2)                                       # [B,T,D]
        return self.post(sel), w


class TFTHurdleModel(nn.Module):
    """
    VSN → LSTM Encoder → LSTM Decoder → Cross-Attention → Hurdle Head

    Output: log_hat [B,H,3]  (same shape as TCNExposureModel)
    Active prob available via return_aux=True.
    """
    def __init__(self, input_dim, ctx_dim, d_model=64, horizon=20, n_heads=4, dropout=0.1):
        super().__init__()
        H = max(64, d_model)

        self.hist_vsn    = VSN(input_dim, d_model, H, dropout)
        self.fut_vsn     = VSN(ctx_dim,   d_model, H, dropout)
        self.enc_lstm    = nn.LSTM(d_model, d_model, batch_first=True)
        self.dec_lstm    = nn.LSTM(d_model + 4, d_model, batch_first=True)
        self.cross_attn  = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)
        self.post_attn   = GRN(d_model, H, d_model, dropout)

        # Hurdle: two separate heads
        self.active_head = nn.Sequential(
            nn.Linear(d_model, H), nn.ReLU(), nn.Dropout(dropout), nn.Linear(H, 3))
        self.mag_head    = nn.Sequential(
            nn.Linear(d_model, H), nn.ReLU(), nn.Dropout(dropout), nn.Linear(H, 3))

    def _hpos(self, B, H, device, dtype):
        h    = torch.arange(1, H+1, device=device, dtype=dtype)
        hn   = h / H
        return torch.stack([hn, torch.sin(2*np.pi*hn), torch.cos(2*np.pi*hn),
                             (h>=13).float()], -1).view(1,H,4).expand(B,H,4)

    def forward(self, x, ctx, return_aux=False):
        hist_sel, hw = self.hist_vsn(x)
        fut_sel,  fw = self.fut_vsn(ctx)

        enc_out, (hn, cn) = self.enc_lstm(hist_sel)   # enc_out: [B,T,D]

        B, H, _ = ctx.shape
        dec_in  = torch.cat([fut_sel, self._hpos(B, H, ctx.device, ctx.dtype)], -1)
        dec_out, _ = self.dec_lstm(dec_in, (hn, cn))  # dec_out: [B,H,D]

        # Cross-attention: decoder attends to full encoder history
        attn_out, attn_w = self.cross_attn(dec_out, enc_out, enc_out, need_weights=True)
        z = self.post_attn(dec_out + attn_out)         # [B,H,D]

        active_logit = self.active_head(z)             # [B,H,3]  raw logit
        p_active     = torch.sigmoid(active_logit)     # [B,H,3]
        log_mag      = F.softplus(self.mag_head(z))    # [B,H,3]
        log_hat      = p_active * log_mag              # [B,H,3]  gated output

        if return_aux:
            return {"log_hat": log_hat, "p_active": p_active,
                    "active_logit": active_logit, "log_mag": log_mag,
                    "hist_w": hw, "fut_w": fw, "attn_w": attn_w}
        return log_hat


def hurdle_loss(log_hat, true_total, true_buy, true_instock,
                active_logit, log_mag,
                w=(0.3, 0.6, 1.0),
                bce_w=1.0, mag_w=1.0, mean_w=0.2,
                hor_alpha=0.4, high_alpha=1.0):

    true = torch.stack([true_total.clamp(0), true_buy.clamp(0), true_instock.clamp(0)], -1)
    tlog = torch.log1p(true)
    tw   = torch.tensor(w, device=log_hat.device).view(1,1,3)

    # sample weights
    denom  = tlog.detach().mean((0,1), keepdim=True).clamp_min(1e-6)
    high_w = 1.0 + high_alpha * tlog.detach() / denom
    H      = true.shape[1]
    h      = torch.arange(1, H+1, device=true.device, dtype=true.dtype).view(1,H,1)
    hor_w  = 1.0 + hor_alpha * (h / H)
    sw     = high_w * hor_w   # [B,H,3]

    # 1. BCE occurrence
    alabel   = (true > 0).float()
    bce      = F.binary_cross_entropy_with_logits(active_logit, alabel, reduction="none")
    bce_loss = (bce * sw * tw).mean()

    # 2. Magnitude Huber on active cells only
    mag_err  = F.huber_loss(log_mag, tlog, delta=1.0, reduction="none")
    mask     = alabel
    num      = (mag_err * mask * sw * tw).sum()
    den      = (mask * sw * tw).sum().clamp_min(1.0)
    mag_loss = num / den

    # 3. Mean scale penalty
    pl       = torch.expm1(log_hat).clamp(0)
    mean_loss= (torch.abs(torch.log1p(pl.mean((0,1))) -
                          torch.log1p(true.mean((0,1)).clamp_min(1e-6))) * tw.view(3)).mean()

    return bce_w * bce_loss + mag_w * mag_loss + mean_w * mean_loss


def _predict_hurdle(model, va_ld, funnel=True):
    rows = []; model.eval()
    with torch.no_grad():
        for b in va_ld:
            aux  = model(b["x"], b["future_ctx"], return_aux=True)
            pred = torch.expm1(aux["log_hat"]).clamp(0).cpu().numpy()
            pact = aux["p_active"].cpu().numpy()
            if funnel:
                pred[:,:,1] = np.minimum(pred[:,:,1], pred[:,:,0])
                pred[:,:,2] = np.minimum(pred[:,:,2], pred[:,:,1])
            B, H = b["future_instock"].shape
            for i in range(B):
                for h in range(H):
                    rows.append({
                        "asin":            b["asin"][i],
                        "order_week":      pd.to_datetime(b["target_week"][h][i]),
                        "horizon":         h + 1,
                        "true_total_dph":  b["future_total"][i,h].item(),
                        "pred_total_dph":  pred[i,h,0],
                        "true_buy_box_dph":b["future_buy"][i,h].item(),
                        "pred_buy_box_dph":pred[i,h,1],
                        "true_instock_dph":b["future_instock"][i,h].item(),
                        "pred_instock_dph":pred[i,h,2],
                        "true_demand":     b["future_demand"][i,h].item(),
                        "p_active_total":  pact[i,h,0],
                        "p_active_buy":    pact[i,h,1],
                        "p_active_instock":pact[i,h,2],
                    })
    return pd.DataFrame(rows)


def run_tft_hurdle(data_raw1, scot_df, n_asins=5000, seed=42,
                   history=52, horizon=20, d_model=64, n_heads=4,
                   batch_size=64, epochs=60, lr=1e-3, patience=8,
                   bce_w=1.0, mag_w=1.0, mean_w=0.2, funnel=True):

    print("\n" + "="*80 + "\nPIPELINE B: TFT-HURDLE\n" + "="*80)

    df = prepare_data(data_raw1, scot_df, n_asins, seed)
    df = filter_extremes(df)
    asin_data, ctx_dim, ctx_cols = load_data(df)
    tr_ld, va_ld = make_loaders(asin_data, history, horizon, batch_size)

    input_dim = next(iter(tr_ld))["x"].shape[-1]
    model = TFTHurdleModel(input_dim, ctx_dim, d_model, horizon, n_heads)
    print(f"Params: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}")

    def loss_fn(out, t, b, i):
        # out is log_hat when called from _train_loop — need aux
        return out   # handled below via custom loop

    # Custom train loop for hurdle (needs return_aux)
    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-5)
    sch = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=max(epochs,1))
    best_val, best_sd, no_imp = float("inf"), None, 0

    for ep in range(epochs):
        model.train(); tl, tn = 0.0, 0
        for b in tr_ld:
            aux  = model(b["x"], b["future_ctx"], return_aux=True)
            loss = hurdle_loss(aux["log_hat"], b["future_total"], b["future_buy"],
                               b["future_instock"], aux["active_logit"], aux["log_mag"],
                               bce_w=bce_w, mag_w=mag_w, mean_w=mean_w)
            opt.zero_grad(); loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0); opt.step()
            tl += loss.item() * b["x"].shape[0]; tn += b["x"].shape[0]
        sch.step()

        model.eval(); vl, vn = 0.0, 0
        with torch.no_grad():
            for b in va_ld:
                aux  = model(b["x"], b["future_ctx"], return_aux=True)
                loss = hurdle_loss(aux["log_hat"], b["future_total"], b["future_buy"],
                                   b["future_instock"], aux["active_logit"], aux["log_mag"],
                                   bce_w=bce_w, mag_w=mag_w, mean_w=mean_w)
                vl += loss.item() * b["x"].shape[0]; vn += b["x"].shape[0]

        tl /= max(tn,1); vl /= max(vn,1)
        print(f"[Hurdle] Ep {ep+1:03d} | train={tl:.5f} | val={vl:.5f}")

        if vl < best_val - 1e-6:
            best_val = vl
            best_sd  = {k: v.clone() for k, v in model.state_dict().items()}
            no_imp   = 0
        else:
            no_imp += 1
        if no_imp >= patience:
            print(f"[Hurdle] Early stop. best_val={best_val:.5f}"); break

    model.load_state_dict(best_sd)

    pred_df = _predict_hurdle(model, va_ld, funnel)

    print("\n--- TFT-Hurdle Evaluation ---")
    diag = evaluate(pred_df)

    return {
        "model":    model,
        "pred_df":  pred_df,
        "diag":     diag,
        "exposure_hat": make_exposure_hat(pred_df),
    }


