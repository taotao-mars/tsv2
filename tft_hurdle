# 2. DATASET
# ============================================================

class ExposureDataset(Dataset):
    def __init__(self, asin_data, history=52, horizon=20, mode="train", val_weeks=20):
        self.data    = asin_data
        self.history = history
        self.horizon = horizon
        self.samples = []

        for asin, d in asin_data.items():
            T = len(d["features"])
            if mode == "train":
                starts = range(max(0, T - val_weeks - horizon - history + 1))
            else:
                s = T - history - horizon
                starts = [s] if s >= 0 else []
            for s in starts:
                self.samples.append((asin, s))

    def __len__(self):
        return len(self.samples)

    @staticmethod
    def _hmean(arr, end, w):
        x = arr[max(0, end - w):end]
        return float(x.mean()) if len(x) else 0.0

    def _make_ctx(self, d, start):
        h, H = self.history, self.horizon
        end   = start + h
        fc    = d["future_ctx"][end:end + H].copy()
        cols  = {c: i for i, c in enumerate(d["ctx_cols"])}

        for src, keys in [
            (d["total_dph"],    ["hist_total_last",  "hist_total_mean4",  "hist_total_mean13"]),
            (d["buy_box_dph"],  ["hist_buy_last",    "hist_buy_mean4",    "hist_buy_mean13"]),
            (d["in_stock_dph"], ["hist_instock_last","hist_instock_mean4","hist_instock_mean13"]),
        ]:
            vals = [
                np.log1p(src[end - 1]) if end > 0 else 0.0,
                np.log1p(self._hmean(src, end, 4)),
                np.log1p(self._hmean(src, end, 13)),
            ]
            for k, v in zip(keys, vals):
                if k in cols:
                    fc[:, cols[k]] = v
        return fc

    def __getitem__(self, i):
        asin, start = self.samples[i]
        d = self.data[asin]
        h, H = self.history, self.horizon
        end = start + h
        return {
            "asin":           asin,
            "target_week":    [str(w)[:10] for w in d["week"][end:end + H]],
            "x":              torch.tensor(d["features"][start:end],     dtype=torch.float32),
            "future_ctx":     torch.tensor(self._make_ctx(d, start),     dtype=torch.float32),
            "future_total":   torch.tensor(d["total_dph"][end:end + H],  dtype=torch.float32),
            "future_buy":     torch.tensor(d["buy_box_dph"][end:end + H],dtype=torch.float32),
            "future_instock": torch.tensor(d["in_stock_dph"][end:end + H],dtype=torch.float32),
            "future_demand":  torch.tensor(d["demand"][end:end + H],     dtype=torch.float32),
        }


def make_loaders(asin_data, history=52, horizon=20, batch_size=64):
    tr = ExposureDataset(asin_data, history, horizon, mode="train")
    va = ExposureDataset(asin_data, history, horizon, mode="val")
    tr_ld = DataLoader(tr, batch_size=batch_size, shuffle=True)
    va_ld = DataLoader(va, batch_size=batch_size, shuffle=False)
    print(f"Train={len(tr)} | Val={len(va)}")
    return tr_ld, va_ld


