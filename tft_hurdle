# 3. METRICS
# ============================================================

def _wape(y, p):
    y, p = np.asarray(y, float), np.asarray(p, float)
    return np.abs(y - p).sum() / (np.abs(y).sum() + 1e-8)

def _corr(y, p, method="pearson"):
    y, p = pd.Series(y, dtype=float), pd.Series(p, dtype=float)
    if y.std() < 1e-8 or p.std() < 1e-8:
        return np.nan
    return y.corr(p, method=method)

def _auc(y_bin, score):
    y_bin = np.asarray(y_bin, int)
    score = np.asarray(score, float)
    if len(np.unique(y_bin)) < 2:
        return np.nan
    return roc_auc_score(y_bin, score)

def _row_metrics(y, p):
    eps = 1e-8
    return {
        "true_mean":  float(y.mean()),
        "pred_mean":  float(p.mean()),
        "ratio":      float(p.mean() / (y.mean() + eps)),
        "WAPE":       _wape(y, p),
        "underbias":  float(np.maximum(y - p, 0).sum() / (np.abs(y).sum() + eps)),
        "active_AUC": _auc(y > 0, p),
        "Pearson":    _corr(y, p, "pearson"),
        "Spearman":   _corr(y, p, "spearman"),
    }

def evaluate(pred_df):
    """
    Print compact by-horizon table for in_stock_dph.
    Returns dict with overall and by_horizon DataFrames.
    """
    specs = [
        ("total_dph",    "true_total_dph",   "pred_total_dph"),
        ("buy_box_dph",  "true_buy_box_dph",  "pred_buy_box_dph"),
        ("in_stock_dph", "true_instock_dph",  "pred_instock_dph"),
    ]

    overall_rows = []
    for name, tc, pc in specs:
        m = _row_metrics(pred_df[tc].values, pred_df[pc].values)
        m["target"] = name
        overall_rows.append(m)
    overall = pd.DataFrame(overall_rows)

    by_h_rows = []
    for h, g in pred_df.groupby("horizon"):
        m = _row_metrics(g["true_instock_dph"].values, g["pred_instock_dph"].values)
        m["horizon"] = h
        by_h_rows.append(m)
    by_h = pd.DataFrame(by_h_rows).sort_values("horizon")

    print("\n" + "=" * 80)
    print("OVERALL")
    print("=" * 80)
    print(overall[["target","true_mean","pred_mean","ratio","WAPE","active_AUC","Spearman"]].round(4).to_string(index=False))

    print("\n" + "=" * 80)
    print("IN_STOCK BY HORIZON")
    print("=" * 80)
    print(by_h[["horizon","true_mean","pred_mean","ratio","WAPE","underbias","active_AUC"]].round(4).to_string(index=False))

    return {"overall": overall, "by_horizon": by_h}


def add_naive_baselines(pred_df, va_ld, ctx_cols):
    idx = {c: i for i, c in enumerate(ctx_cols)}
    rows = []
    for b in va_ld:
        fc = b["future_ctx"].numpy()
        B, H, _ = fc.shape
        for i in range(B):
            for h in range(H):
                row = {"asin": b["asin"][i],
                       "order_week": pd.to_datetime(b["target_week"][h][i]),
                       "horizon": h + 1}
                for mode, keys in [
                    ("last",   ["hist_total_last",   "hist_buy_last",   "hist_instock_last"]),
                    ("mean4",  ["hist_total_mean4",  "hist_buy_mean4",  "hist_instock_mean4"]),
                    ("mean13", ["hist_total_mean13", "hist_buy_mean13", "hist_instock_mean13"]),
                ]:
                    for col, key in zip(["total","buy","instock"], keys):
                        if key in idx:
                            row[f"naive_{col}_{mode}"] = np.expm1(fc[i, h, idx[key]])
                rows.append(row)

    base = pd.DataFrame(rows)
    return pred_df.merge(base, on=["asin", "order_week", "horizon"], how="left")


def make_exposure_hat(pred_df):
    """Final output format for demand model."""
    return pred_df[["asin","order_week",
                    "pred_total_dph","pred_buy_box_dph","pred_instock_dph"]].copy()


