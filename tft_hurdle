    input_dim = next(iter(tr_ld))["x"].shape[-1]
    model = TCNExposureModel(input_dim, ctx_dim, d_model, horizon)
    print(f"Params: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}")

    _train_loop(model, tr_ld, va_ld,
                lambda o, t, b, i: tcn_loss(o, t, b, i),
