    a.insert(0, "method", "best_attn")
    b = result_hurdle["diag"]["by_horizon"].copy()
    b.insert(0, "method", "tft_hurdle")

    comp = pd.concat([a, b]).sort_values(["horizon","method"])
    print("\n" + "="*80)
    print("COMPARISON: IN_STOCK_DPH BY HORIZON")
    print("="*80)
    print(comp[["method","horizon","ratio","WAPE","underbias","active_AUC"]].round(4).to_string(index=False))
    return comp


